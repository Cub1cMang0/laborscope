# Use 'localhost' for local dev, or the Docker service name 'db' inside Docker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=laborscopedb
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# Use 'localhost' for local dev, or the Docker service name 'redis' inside Docker
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Use 'localhost' for local dev outside Docker
# Use 'kafka' when connecting from another Docker service on the same network
KAFKA_HOST=localhost
KAFKA_PORT=9094

# Unique cluster ID for Kafka KRaft mode
# Generate one with: bin/kafka-storage.sh random-uuid (or use the Bitnami image default)
# DONT reuse this across environments
KAFKA_KRAFT_CLUSTER_ID=your_kraft_cluster_id_here

CRAWLER_MAX_DEPTH=2
CRAWLER_MAX_PAGES=500
CRAWLER_REQUEST_DELAY_MS=500
CRAWLER_USER_AGENT=LaborScope/1.0
CRAWLER_TIMEOUT_MS=10000

# Topic name for incoming crawl job requests
KAFKA_TOPIC_CRAWL_JOBS=crawl-jobs

# Topic name for outgoing NLP processing jobs
KAFKA_TOPIC_NLP_JOBS=nlp-jobs
